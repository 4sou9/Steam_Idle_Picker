<Window x:Class="SteamIdlePicker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Idle Picker"
        Height="580" Width="500"
        MinHeight="400" MinWidth="420">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <Style x:Key="GameListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="4,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 検索バー + 言語切替 + 読み込みボタン -->
        <Grid Grid.Row="0" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     VerticalContentAlignment="Center"
                     Padding="6,4"
                     Margin="0,0,6,0"/>
            <Button Grid.Column="1"
                    Content="{DynamicResource Str.LangToggle}"
                    Command="{Binding ToggleLanguageCommand}"
                    Width="34" Padding="0,4" Margin="0,0,6,0"/>
            <Button Grid.Column="2"
                    Content="{DynamicResource Str.RefreshLibrary}"
                    Command="{Binding RefreshLibraryCommand}"
                    Padding="8,4"/>
        </Grid>

        <!-- 情報バー -->
        <Grid Grid.Row="1" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Str.Selected}" FontSize="12"/>
                <TextBlock Text="{Binding SelectedCount, Mode=OneWay}" FontSize="12" FontWeight="Bold"/>
                <TextBlock Text=" / 32" FontSize="12"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource Str.LastFetched}" FontSize="12" Foreground="Gray"/>
                <TextBlock Text="{Binding LastFetched, Mode=OneWay}" FontSize="12" Foreground="Gray"/>
            </StackPanel>
        </Grid>

        <!-- ステータスメッセージ -->
        <TextBlock Grid.Row="2" Foreground="Gray" FontSize="12" Margin="0,0,0,4">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Text" Value="{Binding StatusMessage}"/>
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding StatusMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- アイドル中ステータスバー -->
        <Border Grid.Row="3"
                Background="#EEF7EE" BorderBrush="#88CC88" BorderThickness="1"
                CornerRadius="3" Padding="8,4" Margin="0,0,0,4"
                Visibility="{Binding IsIdling, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="#226622" FontWeight="Bold"
                           Text="{DynamicResource Str.IdlingStatus}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12,0,0,0">
                    <TextBlock Text="{DynamicResource Str.Elapsed}"/>
                    <TextBlock Text="{Binding ElapsedTime, Mode=OneWay}" FontFamily="Consolas"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource Str.Active}"/>
                    <TextBlock Text="{Binding IdlingCount, Mode=OneWay}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource Str.Games}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ゲームリスト -->
        <ListView Grid.Row="4"
                  ItemsSource="{Binding FilteredGames}"
                  ItemContainerStyle="{StaticResource GameListItem}"
                  Margin="0,0,0,8" BorderThickness="1" BorderBrush="#CCCCCC">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="56"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}"
                                  VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="2" Text="{Binding AppId}"
                                   VerticalAlignment="Center" Foreground="Gray"
                                   FontSize="11" HorizontalAlignment="Right" Margin="4,0"/>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsIdling, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{DynamicResource Str.Running}" Foreground="#226622" FontSize="11"
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <Button Content="×" Width="20" Height="20" Padding="0" FontSize="11"
                                    VerticalAlignment="Center"
                                    Command="{Binding DataContext.StopSingleCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                    CommandParameter="{Binding AppId}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- 下部ボタン -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="{DynamicResource Str.ClearAll}"
                    Command="{Binding ClearSelectionCommand}" Padding="10,6"/>
            <Button Grid.Column="2"
                    Content="{Binding ToggleButtonLabel}"
                    Command="{Binding ToggleIdleCommand}"
                    Padding="16,6" MinWidth="130"/>
        </Grid>
    </Grid>
</Window>
