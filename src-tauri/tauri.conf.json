{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Steam Idle Picker",
  "version": "2.1.0",
  "identifier": "com.steamidlepicker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && node scripts/copy-engine.mjs",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Steam Idle Picker",
        "width": 500,
        "height": 580,
        "minWidth": 480,
        "minHeight": 400,
        "resizable": true,
        "center": true,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "engine/*": "engine/"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
